# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
/backend/node_modules/
/shared/node_modules/
/authentication/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ─────────────────────────────────────────────────────────────────
/.next/
/out/
/build/

# ─── Workspace build output ──────────────────────────────────────────────────
/backend/dist/
/shared/dist/
/authentication/dist/

# ─── Prisma ──────────────────────────────────────────────────────────────────
# Generated client lives inside node_modules — never commit it
/node_modules/.prisma/
# Local SQLite dev databases
*.db
*.db-journal
*.sqlite
*.sqlite3

# ─── Environment & secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example          # keep the example in source control
.env.local
.env.production
.env.staging

# ─── Uploads & media ─────────────────────────────────────────────────────────
/public/uploads/
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
devserver*.log
devserver*.err.log
build_output.txt
lint-output.txt

# ─── Testing & coverage ──────────────────────────────────────────────────────
/coverage/
/playwright-report/
/test-results/
.nyc_output/

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
.vscode/.ropeproject
*.swp
*.swo
*~

# ─── Deployment artefacts ────────────────────────────────────────────────────
.vercel/
.cloudflare/
wrangler.toml.local

# ─── Docs / scratch ──────────────────────────────────────────────────────────
/docs/*.draft.*

# ─── Root-level build / log text dumps ───────────────────────────────────────
/build_output.txt
/lint-output.txt

# ─── Local admin data (auto-generated, must never be committed) ──────────────
src/app/admin/_data/admin-users.local.json
