# Frontend
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend
BACKEND_PORT=4000
BACKEND_URL=http://localhost:4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# Auth
AUTH_SESSION_SECRET=change-this-long-random-secret
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
SESSION_TTL=8h
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
COOKIE_DOMAIN=
COOKIE_SECURE=false
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Existing Next admin auth
ADMIN_SESSION_SECRET=change-this-long-random-secret
ADMIN_PASSWORD_HASH=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
AUTH_SUCCESS_REDIRECT=http://localhost:3000/
AUTH_FAILURE_REDIRECT=http://localhost:3000/login?error=oauth_failed

# Admin bootstrap
ADMIN_EMAIL=admin@ibgram.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisPassword1!


# Uploads
UPLOAD_PROVIDER=local
# Directory for local file uploads (relative to repo root). Defaults to public/uploads/.
UPLOAD_DIR=public/uploads
# Max upload size in bytes. Defaults to 5 MB.
UPLOAD_MAX_BYTES=5242880
# Mirrored to client so the media library can show the limit.
NEXT_PUBLIC_UPLOAD_MAX_BYTES=5242880
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2


# Observability
SENTRY_DSN=
LOG_LEVEL=info
